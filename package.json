{
  "name": "markup-sketcher",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "dist:desktop": "npm run build && electron-builder",
    "portable": "powershell -ExecutionPolicy Bypass -File ./scripts/build-portable.ps1"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "lucide": "^1.21.0",
    "validate-html-nesting": "^1.2.4"
  },
  "build": {
    "appId": "com.markupsketcher.app",
    "productName": "Sketcher",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
